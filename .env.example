# Dhan API credentials — obtain from web.dhan.co → My Profile → Access DhanHQ APIs
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here

# Application settings
APP_NAME=tradequant-engine
LOG_LEVEL=INFO
STORAGE_PATH=storage
CACHE_TTL_SECONDS=300

# Pause between symbols during batch-download / panel train (seconds; avoids API overload)
BATCH_SLEEP_SECONDS=3
